# Your protein accessions
ChProSeq <- c('A0A0J9YWK4', 'L5KDM3', 'A0A8C3QEX5', 'A0A493TML3', 'A0A7K9MGK1')
# Initialize list to store pathology results
Pathology_list <- list()
# Process each accession individually
for (prot in ChProSeq) {
cat("Processing", prot, "...\n")
result <- tryCatch({
GetPathology_Biotech(prot)  # your original command
}, error = function(e) {
cat("Failed for", prot, "\n")
return(NULL)
})
Pathology_list[[prot]] <- result
}
# Combine results (skip any NULLs)
PathologyInfo <- do.call(rbind, Pathology_list[!sapply(Pathology_list, is.null)])
# Inspect
if (!is.null(PathologyInfo) && nrow(PathologyInfo) > 0) {
print(PathologyInfo)
} else {
cat("No pathology data retrieved for your proteins.\n")
}
