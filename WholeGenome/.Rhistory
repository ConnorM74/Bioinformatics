library(stringdist)
alignment <- msa(
DNAStringSet(c(sturgeon_cytb, catfish_cytb)),
method = "ClustalW")
sturgeon_ref <- substr(aligned[1], 11, 310)
percent_identity <- function(seq1, seq2) {
# split into characters
s1 <- strsplit(seq1, "")[[1]]
s2 <- strsplit(seq2, "")[[1]]
# make sure they are the same length
if(length(s1) != length(s2)) stop("Sequences must be same length")
# count matches
matches <- sum(s1 == s2)
# return percent
matches / length(s1) * 100
}
percent_identity(sturgeon_ref, catfish_ref)
